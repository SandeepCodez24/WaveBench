{
  "configurations": [
    {
      "name": "windows-gcc-x86",
      "includePath": [
        "${workspaceFolder}/**"
      ],
      "defines": [
        "_WIN32",
        "WIN32",
        "WIN32_LEAN_AND_MEAN",
        "_WIN64",
        "UNICODE",
        "_UNICODE"
      ],
      "compilerPath": "C:/MinGW/bin/gcc.exe",
      "compilerArgs": [
        "-std=c++17"
      ],
      "cStandard": "${default}",
      "cppStandard": "${default}",
      "intelliSenseMode": "windows-gcc-x86"
    }
  ],
  "version": 4
}